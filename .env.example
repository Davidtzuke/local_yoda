# Yoda Configuration
# Copy to .env and customize

# LLM Backend: "local" (default, no API needed), "openai", or "ollama"
YODA_LLM_BACKEND=local

# OpenAI settings (when YODA_LLM_BACKEND=openai)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Ollama settings (when YODA_LLM_BACKEND=ollama)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2
